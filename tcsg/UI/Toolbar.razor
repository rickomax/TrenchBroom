@using System;
@using System.Globalization;
@using Sandbox;
@using Sandbox.UI;
@using System.Threading.Tasks;
@inherits PanelComponent

<root>
	@* Play / Editor toggle hidden until play-mode wiring (NPC spawn, walk
	   controller) is ready. The Player.IsPlayMode flag still exists so the
	   editor-only gating logic stays in place. *@

	<div @ref="LeftPanelRef" class="panel left-panel">
		<div class="panel-content">
			<label class="header">Menu (Q)</label>

			<div class="group">
				<div class="field-row">
					<button class="tool-btn @ResetGateClass" onclick=@ResetScene>NEW</button>
					<button class="tool-btn @ImportGateClass" onclick=@ImportMap>LOAD</button>
					<button class="tool-btn @EditorGateClass" onclick=@ExportMap>SAVE</button>
				</div>
			</div>

			<div class="spacer"></div>

			<div class="group">
				<button class="tool-btn @ToolClass( Player.Tool.Box ) @BrushSpawnGateClass" onclick=@AddBox><span class="label">BOX</span><span class="shortcut">(5)</span></button>
				<div class="spawn-row">
					<button class="tool-btn @ToolClass( Player.Tool.Sphere ) @BrushSpawnGateClass" onclick=@AddSphere><span class="label">SPHERE</span><span class="shortcut">(6)</span></button>
					<TextEntry class="@SegmentEntryClass" Numeric=@true Value:bind=@SphereSegmentsText />
				</div>
				<div class="spawn-row">
					<button class="tool-btn @ToolClass( Player.Tool.Cylinder ) @BrushSpawnGateClass" onclick=@AddCylinder><span class="label">CYLINDER</span><span class="shortcut">(7)</span></button>
					<TextEntry class="@SegmentEntryClass" Numeric=@true Value:bind=@CylinderSegmentsText />
				</div>
				<button class="tool-btn @EntitySpawnGateClass" onclick=@OpenCloud><span class="label">CLOUD</span><span class="shortcut">(8)</span></button>
			</div>

			<div class="spacer"></div>

			<div class="group">
				<button class="tool-btn @CloneDeleteGateClass" onclick=@Clone><span class="label">CLONE</span><span class="shortcut">(Shift+Drag)</span></button>
				<button class="tool-btn @CloneDeleteGateClass" onclick=@Delete><span class="label">DELETE</span><span class="shortcut">(Del)</span></button>
				<button class="tool-btn @HideGateClass" onclick=@Hide><span class="label">HIDE</span><span class="shortcut">(X)</span></button>
				<button class="tool-btn @UnhideGateClass" onclick=@UnhideAll><span class="label">UNHIDE ALL</span><span class="shortcut">(U)</span></button>
			</div>

			<div class="spacer"></div>

			<div class="group">
				<button class="tool-btn @ToolClass( Player.Tool.Move ) @EditorGateClass" onclick=@SetMove><span class="label">MOVE</span><span class="shortcut">(E)</span></button>
				<button class="tool-btn @ToolClass( Player.Tool.Rotate ) @RotateScaleGateClass" onclick=@SetRotate><span class="label">ROTATE</span><span class="shortcut">(R)</span></button>
				<button class="tool-btn @ToolClass( Player.Tool.Scale ) @ScaleGateClass" onclick=@SetScale><span class="label">SCALE</span><span class="shortcut">(T)</span></button>
				<button class="tool-btn @ToolClass( Player.Tool.Slice ) @SliceGateClass" onclick=@SetSlice><span class="label">SLICE</span><span class="shortcut">(C)</span></button>
			</div>

			<div class="spacer"></div>

			<div class="group">
				<button class="tool-btn @SelectionClass( Player.SelectionMode.Brush ) @EditorGateClass" onclick=@SetBrush><span class="label">BRUSH</span><span class="shortcut">(1)</span></button>
				<button class="tool-btn @SelectionClass( Player.SelectionMode.Face ) @EditorGateClass" onclick=@SetFace><span class="label">FACE</span><span class="shortcut">(2)</span></button>
				<button class="tool-btn @SelectionClass( Player.SelectionMode.Vertex ) @VertexGateClass" onclick=@SetVertex><span class="label">VERTEX</span><span class="shortcut">(3)</span></button>
				<button class="tool-btn @SelectionClass( Player.SelectionMode.Entity ) @EditorGateClass" onclick=@SetEntity><span class="label">ENTITY</span><span class="shortcut">(4)</span></button>
			</div>

			<div class="spacer"></div>

			<div class="footer compact">
				<div class="footer-row">
					<div class="footer-col">
						<label class="grid-label">ANGLE</label>
						<div class="grid-stepper">
							<button class="step-btn @(CanDecreaseAngleSnap ? "" : "disabled")"
							        onclick=@DecreaseAngleSnap>−</button>
							<label class="grid-value">@CurrentAngleSnapText</label>
							<button class="step-btn @(CanIncreaseAngleSnap ? "" : "disabled")"
							        onclick=@IncreaseAngleSnap>+</button>
						</div>
					</div>
					<div class="footer-col">
						<label class="grid-label">GRID</label>
						<div class="grid-stepper">
							<button class="step-btn @(CurrentGridSize <= Player.MinGridSize ? "disabled" : "")"
							        onclick=@DecreaseGrid>−</button>
							<label class="grid-value">@CurrentGridSize</label>
							<button class="step-btn @(CurrentGridSize >= Player.MaxGridSize ? "disabled" : "")"
							        onclick=@IncreaseGrid>+</button>
						</div>
					</div>
					<div class="footer-col">
						<label class="grid-label">SPEED</label>
						<div class="grid-stepper">
							<button class="step-btn @(CanDecreaseRunSpeed ? "" : "disabled")"
							        onclick=@DecreaseRunSpeed>−</button>
							<label class="grid-value">@CurrentRunSpeedText</label>
							<button class="step-btn @(CanIncreaseRunSpeed ? "" : "disabled")"
							        onclick=@IncreaseRunSpeed>+</button>
						</div>
					</div>
				</div>
			</div>

			<div class="group">
				<div class="field-row">
					<button class="tool-btn @UndoGateClass" onclick=@Undo><span class="label">UNDO</span><span class="shortcut">(Ctrl+Z)</span></button>
					<button class="tool-btn @RedoGateClass" onclick=@Redo><span class="label">REDO</span><span class="shortcut">(Ctrl+Y)</span></button>
				</div>
			</div>
		</div>

		<ResizeHandle @ref="LeftHandle" class="resize-handle resize-right" />
	</div>

	<div @ref="RightPanelRef" class="panel right-panel">
		<div class="panel-content">
			<label class="header">Operators</label>

			@* UNION and INTERSECTION are hidden: the CSG export format only
			   handles convex brushes and those operators can produce concave
			   results. SUBTRACTION still ships — it carves each selected
			   brush out of every other brush whose volume it overlaps. *@
			<div class="group">
				@*<button class="tool-btn @UnionGateClass" onclick=@Union><span class="label">UNION</span><span class="shortcut">(F)</span></button>*@
				<button class="tool-btn @SubtractGateClass" onclick=@Subtraction><span class="label">SUBTRACTION</span><span class="shortcut">(G)</span></button>
				@*<button class="tool-btn @IntersectGateClass" onclick=@Intersection><span class="label">INTERSECTION</span><span class="shortcut">(H)</span></button>*@
			</div>

			<div class="spacer"></div>

			<label class="header">Mirror</label>

			<div class="group">
				<div class="field-row">
					<button class="tool-btn @MirrorGateClass" onclick=@MirrorX><span class="label">X</span></button>
					<button class="tool-btn @MirrorGateClass" onclick=@MirrorY><span class="label">Y</span></button>
					<button class="tool-btn @MirrorGateClass" onclick=@MirrorZ><span class="label">Z</span></button>
				</div>
			</div>

			<div class="spacer"></div>

			<label class="header">Texture/UV</label>

			<div class="group">
				<Image @ref="TexturePreviewRef" class="texture-preview" Texture=@CurrentTexture></Image>
				<div class="field-row">
					<button class="tool-btn @EditorGateClass" onclick=@SelectTexture><span class="label">SELECT</span><span class="shortcut">(J)</span></button>
					<button class="tool-btn @PickClass @EditorGateClass" onclick=@TogglePick><span class="label">PICK</span><span class="shortcut">(P)</span></button>
				</div>
			</div>

			<label class="field-label">UV TILING</label>
			<div class="field-row">
				<div class="num-stepper">
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeTileX( false ))>−</button>
					<TextEntry class="@NumValueClass" Disabled=@(!HasFacesSelected) Numeric=@true Value:bind=@UVTileXText />
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeTileX( true ))>+</button>
				</div>
				<div class="num-stepper">
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeTileY( false ))>−</button>
					<TextEntry class="@NumValueClass" Disabled=@(!HasFacesSelected) Numeric=@true Value:bind=@UVTileYText />
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeTileY( true ))>+</button>
				</div>
			</div>

			<label class="field-label">UV OFFSET</label>
			<div class="field-row">
				<div class="num-stepper">
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeOffsetX( false ))>−</button>
					<TextEntry class="@NumValueClass" Disabled=@(!HasFacesSelected) Numeric=@true Value:bind=@UVOffsetXText />
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeOffsetX( true ))>+</button>
				</div>
				<div class="num-stepper">
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeOffsetY( false ))>−</button>
					<TextEntry class="@NumValueClass" Disabled=@(!HasFacesSelected) Numeric=@true Value:bind=@UVOffsetYText />
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeOffsetY( true ))>+</button>
				</div>
			</div>

			<label class="field-label">UV ROTATION</label>
			@* Wrap the stepper in a .field-row so the .num-stepper child
			   sits in a row flex context: its flex-grow:1 then grows it
			   horizontally to fill the row, not vertically down the
			   column — the latter swallowed all the remaining panel
			   height and pushed the buttons below into the void. *@

			<div class="field-row">
				<div class="num-stepper">
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeRotation( -1 ))>−</button>
					<TextEntry class="@NumValueClass" Disabled=@(!HasFacesSelected) Numeric=@true Value:bind=@UVRotationText />
					<button class="step-btn-sm @FaceGateClass" onclick=@(() => NudgeRotation( +1 ))>+</button>
				</div>
			</div>
			@* Interactive UV-edit tools. Each is a Tool, like MOVE / ROTATE /
			   SCALE — once active, LMB drag applies the operation to every
			   selected face on its own surface. Disabled when no faces are
			   selected (UV ops only make sense in Face mode). *@
			<div class="field-row">
				<button class="tool-btn @ToolClass( Player.Tool.UVPan ) @UVToolGateClass" onclick=@SetUVPan><span class="label">PAN</span></button>
				<button class="tool-btn @ToolClass( Player.Tool.UVScale ) @UVToolGateClass" onclick=@SetUVScale><span class="label">SCALE</span></button>
				<button class="tool-btn @ToolClass( Player.Tool.UVRotate ) @UVToolGateClass" onclick=@SetUVRotate><span class="label">ROTATE</span></button>
			</div>
			<div class="group">
				<div class="field-row">
					<button class="tool-btn @FitGateClass" onclick=@FitTexture><span class="label">FIT</span></button>
					<button class="tool-btn @FaceGateClass" onclick=@RealignTexture><span class="label">ALIGN</span><span class="shortcut">(M)</span></button>
					<button class="tool-btn @LockClass" onclick=@ToggleLock><span class="label">LOCK</span><span class="shortcut">(L)</span></button>
				</div>
			</div>
			

			<div class="spacer"></div>

			<label class="header">Misc.</label>

			<div class="group">
				<div class="field-row">
					<button class="tool-btn @LocalGizmoClass @LocalGizmoGateClass" onclick=@ToggleLocalGizmo><span class="label">LOCAL</span><span class="shortcut">(O)</span></button>
					<button class="tool-btn @GridEnabledClass @EditorGateClass" onclick=@ToggleGrid><span class="label">GRID</span><span class="shortcut">(K)</span></button>
				</div>
				<div class="field-row">
					<button class="tool-btn @MergedSelectionClass @VertexSnapGateClass" onclick=@ToggleMergedSelection><span class="label">MOVE MERGED</span></button>
				</div>
				<div class="field-row">
					<button class="tool-btn @VertexSnapClass @VertexSnapGateClass" onclick=@ToggleVertexSnap><span class="label">VERTEX SNAP</span><span class="shortcut">(N)</span></button>
				</div>
				<div class="field-row">
					<button class="tool-btn @SelectionMaskClass" onclick=@ToggleSelectionMask><span class="label">MASK</span></button>
				</div>
				<div class="field-row">
					<button class="tool-btn" onclick=@SetPlayMode><span class="label">PLAY</span></button>
				</div>
			</div>

			<div class="spacer"></div>

			<label class="header">Lighting</label>

			<div class="group">
				<div class="field-row">
					<button class="tool-btn @EditorGateClass" onclick=@ClearLight><span class="label">CLEAR</span></button>
					<button class="tool-btn @EditorGateClass" onclick=@BakeLight><span class="label">BAKE</span></button>
				</div>
			</div>

			<label class="field-label">SUN ANGLE</label>
			<div class="field-row">
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunAngleXText />
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunAngleYText />
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunAngleZText />
			</div>

			<label class="field-label">SUN COLOR</label>
			<div class="field-row">
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunColorRText />
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunColorGText />
				<TextEntry class="num-value" Numeric=@true Value:bind=@SunColorBText />
			</div>

			</div>

			<ResizeHandle @ref="RightHandle" class="resize-handle resize-left" />

	</div>

	@* Move-tool box-select marquee. A 2D screen-space rectangle positioned
	   in OnUpdate from a press point captured in the parent panel's local
	   UI coords plus the live cursor (see ApplyBoxSelectMarquee). *@
	<div @ref="BoxSelectMarqueeRef" class="box-select-marquee"></div>

	@if ( IsBaking )
	{
		<div class="baking-banner">BAKING LIGHT... PLEASE WAIT</div>
	}
</root>

@code {
	#region Refs / Sizing State

	public Panel LeftPanelRef { get; set; }
	public Panel RightPanelRef { get; set; }
	public Image TexturePreviewRef { get; set; }
	public ResizeHandle LeftHandle { get; set; }
	public ResizeHandle RightHandle { get; set; }
	public Panel BoxSelectMarqueeRef { get; set; }

	const float MinPanelWidth = 140f;
	const float MaxPanelWidth = 400f;

	float LeftPanelWidth  = 264f;
	float RightPanelWidth = 264f;

	float _appliedLeftWidth  = -1f;
	float _appliedRightWidth = -1f;

	bool _wiredHandles;

	void WireHandles()
	{
		if ( _wiredHandles ) return;
		if ( LeftHandle is null || RightHandle is null ) return;

		// Method-group references (not lambdas) so s&box hot-reload can
		// remap the delegate target by name on every rebuild. Capturing
		// lambdas here gave them compiler-generated names like
		// <WireHandles>b__N_M whose ordinal shifts whenever this file
		// recompiles, which broke the next mouse-down with
		// "Unable to find matching substitution for a lambda method".
		LeftHandle.OnDragMoved  = OnLeftHandleDrag;
		RightHandle.OnDragMoved = OnRightHandleDrag;

		_wiredHandles = true;
	}

	void OnLeftHandleDrag( float dx )  => ApplyResize( LeftHandle,  ref LeftPanelWidth,  dx );
	void OnRightHandleDrag( float dx ) => ApplyResize( RightHandle, ref RightPanelWidth, -dx );

	// Apply a signed width delta and stop the drag if the clamp ate part of it
	// — otherwise the cursor keeps drifting past the panel edge while the
	// width is pinned at its limit, breaking the 1:1 mapping until the user
	// drags all the way back.
	void ApplyResize( ResizeHandle handle, ref float width, float signedDelta )
	{
		var newWidth = Math.Clamp( width + signedDelta, MinPanelWidth, MaxPanelWidth );
		var applied = newWidth - width;
		width = newWidth;
		ApplyWidths();
		if ( MathF.Abs( applied - signedDelta ) > 0.01f )
		{
			handle.EndDrag();
		}
	}

	void ApplyWidths()
	{
		if ( LeftPanelRef is not null && _appliedLeftWidth != LeftPanelWidth )
		{
			LeftPanelRef.Style.Width = LeftPanelWidth;
			LeftPanelRef.Style.Dirty();
			_appliedLeftWidth = LeftPanelWidth;
		}
		if ( RightPanelRef is not null && _appliedRightWidth != RightPanelWidth )
		{
			RightPanelRef.Style.Width = RightPanelWidth;
			RightPanelRef.Style.Dirty();
			_appliedRightWidth = RightPanelWidth;
		}
	}

	protected override void OnUpdate()
	{
		WireHandles();
		ApplyWidths();
		ApplyBoxSelectMarquee();
	}

	// Track the press point in the parent panel's local UI coordinates so
	// the rectangle stays glued to the cursor regardless of ScreenPanel's
	// "Auto Screen Scale" setting. Panel.MousePosition reports the cursor
	// in raw screen pixels relative to the panel's origin (same value
	// you'd read from Mouse.Position when the panel covers the screen),
	// but Style.Left / Top / Width / Height live in UI logical pixels —
	// the two diverge by the ancestor ScreenPanel's Scale. Multiplying
	// by Panel.ScaleFromScreen (= 1 / cumulative Scale) converts raw
	// screen pixels into the UI-pixel space Style expects.
	Vector2 _boxSelectPressUI;
	bool _boxSelectPressArmed;

	// Drive the move-tool marquee div's position/size every frame. Bypasses
	// Razor's BuildHash path because the cursor position changes every
	// frame — including it in the hash would re-render the whole toolbar
	// on every cursor move.
	void ApplyBoxSelectMarquee()
	{
		if ( BoxSelectMarqueeRef is null ) return;
		var parent = BoxSelectMarqueeRef.Parent;
		if ( parent is null ) return;

		// Capture press in UI pixels by applying the parent's screen→UI
		// scale once, on the press frame. Storing the UI value (not the
		// raw one) keeps the anchor stable even if the scale somehow
		// shifts mid-drag.
		if ( Input.Pressed( "attack1" ) )
		{
			_boxSelectPressUI = parent.MousePosition * parent.ScaleFromScreen;
			_boxSelectPressArmed = true;
		}
		else if ( !Input.Down( "attack1" ) )
		{
			_boxSelectPressArmed = false;
		}

		var player = Player.Instance;
		var visible = _boxSelectPressArmed
			&& player is not null
			&& player.IsBoxSelecting;

		if ( !visible )
		{
			if ( BoxSelectMarqueeRef.Style.Display != DisplayMode.None )
			{
				BoxSelectMarqueeRef.Style.Display = DisplayMode.None;
				BoxSelectMarqueeRef.Style.Dirty();
			}
			return;
		}

		var cursor = parent.MousePosition * parent.ScaleFromScreen;
		var minX = MathF.Min( _boxSelectPressUI.x, cursor.x );
		var minY = MathF.Min( _boxSelectPressUI.y, cursor.y );
		var maxX = MathF.Max( _boxSelectPressUI.x, cursor.x );
		var maxY = MathF.Max( _boxSelectPressUI.y, cursor.y );
		BoxSelectMarqueeRef.Style.Display = DisplayMode.Flex;
		BoxSelectMarqueeRef.Style.Left = minX;
		BoxSelectMarqueeRef.Style.Top = minY;
		BoxSelectMarqueeRef.Style.Width = maxX - minX;
		BoxSelectMarqueeRef.Style.Height = maxY - minY;
		BoxSelectMarqueeRef.Style.Dirty();
	}

	#endregion

	#region Grid

	float CurrentGridSize => Player.Instance?.GridSize ?? 0f;
	void DecreaseGrid() => Player.Instance?.DecreaseGridAction();
	void IncreaseGrid() => Player.Instance?.IncreaseGridAction();

	#endregion

	#region Speed

	const float RunSpeedStep = 25f;
	const float RunSpeedMin = 50f;
	const float RunSpeedMax = 1000f;

	float CurrentRunSpeed => Player.Instance?.RunSpeed ?? 0f;
	string CurrentRunSpeedText => CurrentRunSpeed.ToString( "0", CultureInfo.InvariantCulture );
	bool CanDecreaseRunSpeed => Player.Instance is not null && CurrentRunSpeed > RunSpeedMin;
	bool CanIncreaseRunSpeed => Player.Instance is not null && CurrentRunSpeed < RunSpeedMax;

	// Shift held -> 10% of current speed instead of the absolute step, so
	// power users can tune slow speeds without it jumping past the value.
	static float RunSpeedDelta( float current ) => ShiftHeld() ? MathF.Max( 1f, current * 0.1f ) : RunSpeedStep;
	void DecreaseRunSpeed() { if ( Player.Instance is not null ) Player.Instance.RunSpeed = MathF.Max( RunSpeedMin, CurrentRunSpeed - RunSpeedDelta( CurrentRunSpeed ) ); }
	void IncreaseRunSpeed() { if ( Player.Instance is not null ) Player.Instance.RunSpeed = MathF.Min( RunSpeedMax, CurrentRunSpeed + RunSpeedDelta( CurrentRunSpeed ) ); }

	#endregion

	#region Shift Modifier

	// Reads the live Shift state at click time. The s&box "Run" action is
	// bound to Shift by default and is the same action used elsewhere in the
	// editor for shift-modified behaviours (e.g. clone-on-drag).
	static bool ShiftHeld() => Input.Down( "Run" );

	#endregion

	#region Angle Snap

	float CurrentAngleSnap => Player.Instance?.AngleSnap ?? 0f;
	string CurrentAngleSnapText => CurrentAngleSnap.ToString( "0.#####", CultureInfo.InvariantCulture ) + "°";
	bool CanIncreaseAngleSnap => Player.Instance?.CanIncreaseAngleSnap ?? false;
	bool CanDecreaseAngleSnap => Player.Instance?.CanDecreaseAngleSnap ?? false;
	void DecreaseAngleSnap() { if ( Player.Instance is not null ) Player.Instance.DecreaseAngleSnap(); }
	void IncreaseAngleSnap() { if ( Player.Instance is not null ) Player.Instance.IncreaseAngleSnap(); }

	#endregion

	#region Active-state Helpers

	string ToolClass( Player.Tool t ) => Player.Instance is not null && Player.Instance.CurrentTool == t ? "pressed" : "";
	string SelectionClass( Player.SelectionMode m ) => Player.Instance is not null && Player.Instance.Selection == m ? "pressed" : "";

	#endregion

	#region Primitives / Object / Transform / Selection

	void OpenCloud()   => Player.Instance.OpenCloudAction();
	bool IsPlayMode    => Player.Instance?.IsPlayMode ?? false;
	bool IsBaking          => Player.Instance?.IsBaking ?? false;
	string EditorGateClass => (IsPlayMode || IsBaking) ? "disabled" : "";
	void SetEditorMode() { if ( Player.Instance is not null && Player.Instance.IsPlayMode ) Player.Instance.TogglePlayModeAction(); }
	void SetPlayMode()   { if ( Player.Instance is not null && !Player.Instance.IsPlayMode ) Player.Instance.TogglePlayModeAction(); }

	void AddBox()      => Player.Instance.AddBoxAction();
	void AddSphere()   => Player.Instance.AddSphereAction();
	void AddCylinder() => Player.Instance.AddCylinderAction();

	// Segment-count fields next to the SPHERE / CYLINDER buttons drive
	// the slice / stack counts of the next primitive the user spawns.
	// Default to the brush classes' built-in defaults so the initial UI
	// matches what spawning would have produced before this feature
	// existed.
	string SphereSegmentsText
	{
		get => (Player.Instance?.SphereSegments ?? Player.DefaultSphereSegments).ToString( CultureInfo.InvariantCulture );
		set
		{
			if ( Player.Instance is null ) return;
			if ( int.TryParse( value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var n ) )
			{
				Player.Instance.SphereSegments = n;
			}
		}
	}

	string CylinderSegmentsText
	{
		get => (Player.Instance?.CylinderSegments ?? Player.DefaultCylinderSegments).ToString( CultureInfo.InvariantCulture );
		set
		{
			if ( Player.Instance is null ) return;
			if ( int.TryParse( value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var n ) )
			{
				Player.Instance.CylinderSegments = n;
			}
		}
	}
	// Spawning a brush primitive only makes sense in Brush selection mode;
	// likewise CLOUD spawns belong to Entity mode. Greying these out
	// elsewhere stops the user from launching a draw tool whose result will
	// flip them into a different mode unexpectedly.
	bool IsBrushMode  => Player.Instance?.Selection == Player.SelectionMode.Brush;
	bool IsEntityMode => Player.Instance?.Selection == Player.SelectionMode.Entity;
	string BrushSpawnGateClass  => (IsPlayMode || IsBaking || !IsBrushMode) ? "disabled" : "";
	string EntitySpawnGateClass => (IsPlayMode || IsBaking || !IsEntityMode) ? "disabled" : "";

	// Component attributes (e.g. <TextEntry class=... />) don't support
	// mixed literal+expression content the way plain HTML elements do, so
	// the "segment-entry @BrushSpawnGateClass" combo is pre-composed here
	// as a single string expression. Same pattern as NumValueClass below.
	string SegmentEntryClass => $"segment-entry {BrushSpawnGateClass}";

