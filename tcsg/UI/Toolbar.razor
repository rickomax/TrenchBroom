	void SetSlice()  => Player.Instance.SliceAction();
	// Clicking the already-active UV tool toggles it OFF and returns to
	// the regular Move tool, keeping Face selection mode. Clicking a
	// different UV tool just switches between them (so e.g. PAN → SCALE
	// doesn't bounce back through Move). Anything else (Move, Rotate,
	// Scale, Slice…) deselecting a UV tool happens automatically via
	// single-value CurrentTool — these helpers only need to handle the
	// toggle-off-with-the-same-button case.
	void SetUVPan()
	{
		if ( Player.Instance is null ) return;
		if ( Player.Instance.CurrentTool == Player.Tool.UVPan )
			Player.Instance.MoveAction();
		else
			Player.Instance.UVPanAction();
	}
	void SetUVScale()
	{
		if ( Player.Instance is null ) return;
		if ( Player.Instance.CurrentTool == Player.Tool.UVScale )
			Player.Instance.MoveAction();
		else
			Player.Instance.UVScaleAction();
	}
	void SetUVRotate()
	{
		if ( Player.Instance is null ) return;
		if ( Player.Instance.CurrentTool == Player.Tool.UVRotate )
			Player.Instance.MoveAction();
		else
			Player.Instance.UVRotateAction();
	}
	bool CanSlice    => Player.Instance?.CanSlice ?? false;
