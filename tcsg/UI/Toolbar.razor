	float UVTileY    => Player.Instance?.UVTileY ?? float.NaN;
	float UVOffsetX  => Player.Instance?.UVOffsetX ?? float.NaN;
	float UVOffsetY  => Player.Instance?.UVOffsetY ?? float.NaN;
	float UVRotation => Player.Instance?.UVRotation ?? 0f;

	static string FormatFloat( float v, string fmt ) => float.IsNaN( v ) ? "—" : v.ToString( fmt, CultureInfo.InvariantCulture );

	string UVTileXText    { get => FormatFloat( UVTileX,   "0.0000" ); set => CommitUV( value, f => Player.Instance.UVTileX = f ); }
	string UVTileYText    { get => FormatFloat( UVTileY,   "0.0000" ); set => CommitUV( value, f => Player.Instance.UVTileY = f ); }
	string UVOffsetXText  { get => FormatFloat( UVOffsetX, "0.0" );    set => CommitUV( value, f => Player.Instance.UVOffsetX = f ); }
	string UVOffsetYText  { get => FormatFloat( UVOffsetY, "0.0" );    set => CommitUV( value, f => Player.Instance.UVOffsetY = f ); }
	string UVRotationText { get => FormatFloat( UVRotation, "0" );     set => CommitUV( value, f => Player.Instance.UVRotation = ((f % 360f) + 360f) % 360f ); }

	void CommitUV( string text, Action<float> apply )
	{
		if ( Player.Instance is null || string.IsNullOrWhiteSpace( text ) ) return;
		var cleaned = text.Replace( ',', '.' ).Replace( "°", "" ).Trim();
		if ( !float.TryParse( cleaned, NumberStyles.Float, CultureInfo.InvariantCulture, out var f ) ) return;
		apply( f );
	}

	#endregion

	#region Nudge

	const float DefaultScaleFallback = 0.25f;

	static float SafeScale( float s ) => (float.IsNaN( s ) || MathF.Abs( s ) < 1e-7f) ? DefaultScaleFallback : s;

	// Tile is multiplicative: regular click doubles or halves; Shift trims the
	// step to a 10% multiplicative nudge instead.
	void NudgeTileX( bool up )
	{
		if ( Player.Instance is null ) return;
		var cur = Player.Instance.UVTileX; if ( float.IsNaN( cur ) ) return;
		var factor = ShiftHeld() ? (up ? 1.1f : 1f / 1.1f) : (up ? 2f : 0.5f);
		Player.Instance.UVTileX = SafeScale( cur ) * factor;
	}
	void NudgeTileY( bool up )
	{
		if ( Player.Instance is null ) return;
		var cur = Player.Instance.UVTileY; if ( float.IsNaN( cur ) ) return;
		var factor = ShiftHeld() ? (up ? 1.1f : 1f / 1.1f) : (up ? 2f : 0.5f);
		Player.Instance.UVTileY = SafeScale( cur ) * factor;
	}
	// Offset / rotation are additive: Shift uses 10% of the regular step.
	void NudgeOffsetX( bool positive )
	{
		if ( Player.Instance is null ) return;
		var cur = Player.Instance.UVOffsetX; if ( float.IsNaN( cur ) ) return;
		var amount = (Player.Instance.GridSize > 0 ? Player.Instance.GridSize : 1f) / SafeScale( Player.Instance.UVTileX );
		if ( ShiftHeld() ) amount *= 0.1f;
		Player.Instance.UVOffsetX = cur + (positive ? amount : -amount);
	}
	void NudgeOffsetY( bool positive )
	{
		if ( Player.Instance is null ) return;
		var cur = Player.Instance.UVOffsetY; if ( float.IsNaN( cur ) ) return;
		var amount = (Player.Instance.GridSize > 0 ? Player.Instance.GridSize : 1f) / SafeScale( Player.Instance.UVTileY );
		if ( ShiftHeld() ) amount *= 0.1f;
		Player.Instance.UVOffsetY = cur + (positive ? amount : -amount);
	}
	void NudgeRotation( int dir )
	{
		if ( Player.Instance is null ) return;
		// Fixed 15° step — UV rotation is decoupled from the brush rotate
		// gizmo's angle snap. Shift takes a finer 1.5° step.
		var step = ShiftHeld() ? 1.5f : 15f;
		Player.Instance.UVRotation = Player.Instance.UVRotation + dir * step;
	}

	#endregion

	#region Lighting

	void ClearLight()
	{
		var sun = Player.Instance?._sunLight;
		if ( sun is not null )
			sun.SkyColor = new Color( 0.5f, 0.5f, 0.5f );
		Player.Instance?._shLightVolume?.Clear();
	}

	async void BakeLight()
	{
		var player = Player.Instance;
		var volume = player?._shLightVolume;
		if ( volume is null ) return;
		var sun = player._sunLight;
		if ( sun is not null )
			sun.SkyColor = Color.Black;
		player.IsBaking = true;
		try
		{
			volume.ExtendToSceneBounds();
			await volume.Bake();
		}
		finally
		{
			player.IsBaking = false;
		}
	}

	Angles SunAngles
	{
		get => Player.Instance?._sunLight?.WorldRotation.Angles() ?? default;
		set
		{
			var sun = Player.Instance?._sunLight;
			if ( sun is not null )
				sun.WorldRotation = Rotation.From( value );
		}
	}

	Color SunColor
	{
		get => Player.Instance?._sunLight?.LightColor ?? Color.White;
		set
		{
			var sun = Player.Instance?._sunLight;
			if ( sun is not null )
				sun.LightColor = value;
		}
	}

	string SunAngleXText { get => FormatFloat( SunAngles.pitch, "0.0" ); set => CommitSunAngle( value, ( ref Angles a, float f ) => a.pitch = f ); }
	string SunAngleYText { get => FormatFloat( SunAngles.yaw,   "0.0" ); set => CommitSunAngle( value, ( ref Angles a, float f ) => a.yaw = f ); }
	string SunAngleZText { get => FormatFloat( SunAngles.roll,  "0.0" ); set => CommitSunAngle( value, ( ref Angles a, float f ) => a.roll = f ); }

	delegate void AngleSetter( ref Angles a, float f );
	void CommitSunAngle( string text, AngleSetter apply )
	{
		if ( Player.Instance?._sunLight is null || string.IsNullOrWhiteSpace( text ) ) return;
		var cleaned = text.Replace( ',', '.' ).Replace( "°", "" ).Trim();
		if ( !float.TryParse( cleaned, NumberStyles.Float, CultureInfo.InvariantCulture, out var f ) ) return;
		var angles = SunAngles;
		apply( ref angles, f );
		SunAngles = angles;
	}

	string SunColorRText { get => FormatFloat( SunColor.r, "0.000" ); set => CommitSunColor( value, 0 ); }
	string SunColorGText { get => FormatFloat( SunColor.g, "0.000" ); set => CommitSunColor( value, 1 ); }
	string SunColorBText { get => FormatFloat( SunColor.b, "0.000" ); set => CommitSunColor( value, 2 ); }

	void CommitSunColor( string text, int channel )
	{
		if ( Player.Instance?._sunLight is null || string.IsNullOrWhiteSpace( text ) ) return;
		var cleaned = text.Replace( ',', '.' ).Trim();
		if ( !float.TryParse( cleaned, NumberStyles.Float, CultureInfo.InvariantCulture, out var f ) ) return;
		var c = SunColor;
		switch ( channel )
		{
			case 0: c = c.WithRed( f ); break;
			case 1: c = c.WithGreen( f ); break;
			case 2: c = c.WithBlue( f ); break;
		}
		SunColor = c;
	}

	#endregion

	protected override int BuildHash()
	{
		var hash = new HashCode();

		hash.Add(CurrentGridSize);
		hash.Add(UVTileX);
		hash.Add(UVTileY);
		hash.Add(UVOffsetX);
		hash.Add(UVOffsetY);
		hash.Add(UVRotation);
		hash.Add(CurrentTexturePath);

		hash.Add(Player.Instance?.CurrentTool);
		hash.Add(Player.Instance?.Selection);
		hash.Add(CurrentAngleSnap);
		hash.Add(HasFacesSelected);

		hash.Add(CanUnion);
		hash.Add(CanSubtract);
		hash.Add(CanIntersect);
		hash.Add(LockUVs);
		hash.Add(CanUndo);
		hash.Add(CanRedo);
		hash.Add(IsPlayMode);

		hash.Add(IsBaking);
		hash.Add(SunAngles);
		hash.Add(SunColor);
		hash.Add(CanSlice);
		hash.Add(VertexSnap);
		hash.Add(MergedSelection);
		hash.Add(VertexSelectionActive);
		hash.Add(IsPickingTexture);
		hash.Add(CanUseVertexMode);
		hash.Add(CanUseScaleTool);
		hash.Add(CanUseUVTools);
		hash.Add(CanMirror);
		hash.Add(SelectionMask);

		hash.Add(CurrentRunSpeed);
		hash.Add(LocalGizmo);
		hash.Add(LocalGizmoApplies);
		hash.Add(GridEnabled);
		hash.Add(CanHide);
		hash.Add(CanUnhideAll);

		hash.Add(Player.Instance?.SphereSegments ?? 0);
		hash.Add(Player.Instance?.CylinderSegments ?? 0);

		return hash.ToHashCode();
	}
