	string ScaleGateClass => (IsPlayMode || IsBaking || !CanUseScaleTool) ? "disabled" : "";
	string VertexGateClass => (IsPlayMode || IsBaking || !CanUseVertexMode) ? "disabled" : "";
	string CloneDeleteGateClass => (IsPlayMode || IsBaking || !CanCloneOrDelete) ? "disabled" : "";

