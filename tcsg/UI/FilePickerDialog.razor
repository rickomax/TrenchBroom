@using System
@using System.Linq
@using Sandbox
@using Sandbox.UI
@inherits PanelComponent

<root class="@(IsOpen ? "open" : "closed")">
	@if ( IsOpen )
	{
		<div class="overlay" onclick=@Cancel></div>

		<div class="dialog">
			<div class="header">
				<label class="title">@Title</label>
				<button class="close-btn" onclick=@Cancel>×</button>
			</div>

			<div class="path-bar">
				<button class="up-btn @(CanGoUp ? "" : "disabled")" onclick=@GoUp>↑</button>
				@* Bound to a property whose setter is a no-op so the entry
				   is effectively read-only — users can click in, select
				   text, and copy the virtual path, but typing doesn't
				   stick. *@
				<TextEntry class="current-path" Value:bind=@CurrentPathDisplay />
			</div>

			<div class="list">
				@foreach ( var dir in Directories )
				{
					<button class="entry directory" onclick=@(() => EnterDirectory( dir ))>
						<label class="entry-icon">[D]</label>
						<label class="entry-name">@dir</label>
					</button>
				}

				@foreach ( var file in Files )
				{
					<button class="entry file @(SelectedFile == file ? "selected" : "")"
					        onclick=@(() => SelectFile( file ))
					        ondoubleclick=@(() => ConfirmFile( file ))>
						@if ( IsImageFile( file ) )
						{
							<Image class="entry-thumb" Texture=@GetPreview( file )></Image>
						}
						else
						{
							<label class="entry-icon">[F]</label>
						}
						<label class="entry-name">@file</label>
					</button>
				}

				@if ( Directories.Count == 0 && Files.Count == 0 )
				{
					<label class="empty">@EmptyMessage</label>
				}
			</div>

			@if ( IsSaveMode )
			{
				<div class="save-row">
					<label class="save-label">Name</label>
					<TextEntry class="save-name" Value:bind=@SaveFileName />
				</div>
			}

			<div class="footer">
				<label class="selection-label">@( string.IsNullOrEmpty( SelectedFile ) ? "" : SelectedFile )</label>
				<button class="btn cancel" onclick=@Cancel>CANCEL</button>
				@if ( IsSaveMode )
				{
					<button class="btn confirm @(string.IsNullOrWhiteSpace( SaveFileName ) ? "disabled" : "")"
					        onclick=@ConfirmSave>SAVE</button>
				}
				else
				{
					<button class="btn confirm @(string.IsNullOrEmpty( SelectedFile ) ? "disabled" : "")"
					        onclick=@(() => ConfirmFile( SelectedFile ))>OPEN</button>
				}
			</div>

			<div class="disk-path-row">
				<label class="disk-path-prefix">Place files in:</label>
				@* Same read-only-by-no-op-setter pattern as the path-bar
				   entry — gives the user a selectable, copyable view of
				   the absolute OS path so they can open it in their
				   file explorer. *@
				<TextEntry class="disk-path" Value:bind=@SystemPathDisplay />
			</div>
		</div>
	}
</root>
@code {
	public bool IsOpen { get; private set; }
	public string Title { get; private set; } = "Select File";
	public string CurrentPath { get; private set; } = "";
	public string SelectedFile { get; private set; } = "";
	public string EmptyMessage { get; private set; } = "";
	public List<string> Directories { get; } = new();
	public List<string> Files { get; } = new();

	public bool IsSaveMode { get; private set; }
	public string SaveFileName { get; set; } = "";
	string _saveDefaultExtension = "";

	public bool CanGoUp => !string.IsNullOrEmpty( CurrentPath );

	// Physical disk path of FileSystem.Data + the current browse subfolder, so
	// the user knows where to drop files. GetFullPath returns null when the
	// path isn't on disk; fall back to the virtual /data/... display in that
	// case.
	string SystemPath
	{
		get
		{
			var browse = string.IsNullOrEmpty( CurrentPath ) ? "/" : "/" + CurrentPath;
			try
			{
				var disk = FileSystem.Data?.GetFullPath( browse );
				if ( !string.IsNullOrEmpty( disk ) ) return disk;
			}
			catch { }
			return $"/data{browse}";
		}
	}

	// Display-only properties bound to the path TextEntry controls.
	// TextEntry requires a settable property to bind to, but we don't
	// want the user's keystrokes to change the path — the setter is a
	// no-op and the next StateHasChanged cycle (CurrentPath / SystemPath
	// are in BuildHash) reverts the visible value back to the getter.
	// The net effect: users can click in, select, and copy; they can't
	// usefully type.
	public string CurrentPathDisplay
	{
		get => "/data/" + CurrentPath;
		set { }
	}

	public string SystemPathDisplay
	{
		get => SystemPath;
		set { }
	}

	string _pattern = "*";
	bool _showFiles = true;
	Action<string> _onSelected;
	Action _onCancelled;

	readonly Dictionary<string, Texture> _previewCache = new( StringComparer.OrdinalIgnoreCase );
	static readonly string[] _imageExtensions = { ".png", ".jpg", ".jpeg", ".bmp", ".tga" };

	static bool IsImageFile( string file )
	{
		if ( string.IsNullOrEmpty( file ) ) return false;
		var dot = file.LastIndexOf( '.' );
		if ( dot < 0 ) return false;
		var ext = file.Substring( dot ).ToLowerInvariant();
		for ( var i = 0; i < _imageExtensions.Length; i++ )
		{
			if ( ext == _imageExtensions[i] ) return true;
		}
		return false;
	}

	Texture GetPreview( string file )
	{
		var full = string.IsNullOrEmpty( CurrentPath ) ? file : $"{CurrentPath}/{file}";
		if ( _previewCache.TryGetValue( full, out var cached ) ) return cached;

		Texture tex = null;
		try
		{
			var data = FileSystem.Data.ReadAllBytes( full ).ToArray();
			var img = StbImageSharp.ImageResult.FromMemory( data, StbImageSharp.ColorComponents.RedGreenBlueAlpha );
			var bmp = new Bitmap( img.Width, img.Height );
			var colors = new Color[img.Width * img.Height];
			for ( var i = 0; i < colors.Length; i++ )
			{
				var r = img.Data[i * 4 + 0];
				var g = img.Data[i * 4 + 1];
				var b = img.Data[i * 4 + 2];
				var a = img.Data[i * 4 + 3];
				colors[i] = Color.FromBytes( r, g, b, a );
			}
			bmp.SetPixels( colors );
			tex = bmp.ToTexture();
		}
		catch
		{
			// leave tex null; renders empty thumbnail
		}
		_previewCache[full] = tex;
		return tex;
	}

	public void Show(
		string title,
		string pattern = "*",
		string initialPath = "",
		Action<string> onSelected = null,
		Action onCancelled = null,
		bool showFiles = true,
		string initialFile = "" )
	{
		Title = title ?? "Select File";
		_pattern = string.IsNullOrWhiteSpace( pattern ) ? "*" : pattern;
		_showFiles = showFiles;
		_onSelected = onSelected;
		_onCancelled = onCancelled;
		IsSaveMode = false;
		SaveFileName = "";
		_saveDefaultExtension = "";

		CurrentPath = NormalisePath( initialPath );
		SelectedFile = "";
		EmptyMessage = "Loading…";

		IsOpen = true;
		Refresh();
		// Preselect the requested file if it actually lives in the listed
		// directory — Refresh clears SelectedFile, so this has to run after
		// it. Callers pass the filename they last operated on (e.g.
		// SelectedTexturePath) to re-anchor the dialog on reopen.
		if ( !string.IsNullOrEmpty( initialFile ) && Files.Contains( initialFile ) )
		{
			SelectedFile = initialFile;
		}
		StateHasChanged();
	}

	public void ShowSave(
		string title,
		string pattern,
		string defaultExtension,
		string defaultFileName,
		string initialPath = "",
		Action<string> onSaved = null,
		Action onCancelled = null )
	{
		Title = title ?? "Save File";
		_pattern = string.IsNullOrWhiteSpace( pattern ) ? "*" : pattern;
		_showFiles = true;
		_onSelected = onSaved;
		_onCancelled = onCancelled;
		IsSaveMode = true;
		SaveFileName = defaultFileName ?? "";
		_saveDefaultExtension = defaultExtension ?? "";

		CurrentPath = NormalisePath( initialPath );
		SelectedFile = "";
		EmptyMessage = "Loading…";

		IsOpen = true;
		Refresh();
		StateHasChanged();
	}

	void ConfirmSave()
	{
		var name = (SaveFileName ?? "").Trim();
		if ( string.IsNullOrEmpty( name ) ) return;
		if ( !string.IsNullOrEmpty( _saveDefaultExtension ) && name.IndexOf( '.' ) < 0 )
		{
			name += _saveDefaultExtension;
		}
		var full = string.IsNullOrEmpty( CurrentPath ) ? name : $"{CurrentPath}/{name}";
		var callback = _onSelected;
		Hide();
		callback?.Invoke( full );
	}

	public void Hide()
	{
		if ( !IsOpen ) return;
		IsOpen = false;
		_onSelected = null;
		_onCancelled = null;
		Directories.Clear();
		Files.Clear();
		_previewCache.Clear();
		SelectedFile = "";
		IsSaveMode = false;
		SaveFileName = "";
		_saveDefaultExtension = "";
		StateHasChanged();
	}

	void Refresh()
	{
		Directories.Clear();
		Files.Clear();
		SelectedFile = "";

		var fs = FileSystem.Data;
		if ( fs is null )
		{
			EmptyMessage = "FileSystem.Data is not available.";
			return;
		}

		var browse = string.IsNullOrEmpty( CurrentPath ) ? "/" : "/" + CurrentPath;
		if ( !fs.DirectoryExists( browse ) )
		{
			CurrentPath = "";
			browse = "/";
		}

		try
		{
			foreach ( var d in fs.FindDirectory( browse ).OrderBy( s => s, StringComparer.OrdinalIgnoreCase ) )
			{
				Directories.Add( d );
			}

			if ( _showFiles )
			{
				var seen = new HashSet<string>( StringComparer.OrdinalIgnoreCase );
				foreach ( var pattern in SplitPatterns( _pattern ) )
				{
					foreach ( var f in fs.FindFile( browse, pattern ) )
					{
						if ( seen.Add( f ) ) Files.Add( f );
					}
				}
				Files.Sort( StringComparer.OrdinalIgnoreCase );
			}
		}
		catch ( Exception ex )
		{
			EmptyMessage = $"Error reading directory: {ex.Message}";
			return;
		}

		EmptyMessage = _showFiles
			? $"No files matching '{_pattern}' in this folder."
			: "No subfolders here.";
	}

	static IEnumerable<string> SplitPatterns( string pattern )
	{
		if ( string.IsNullOrWhiteSpace( pattern ) ) return new[] { "*" };
		return pattern
			.Split( new[] { ';', ',' }, StringSplitOptions.RemoveEmptyEntries )
			.Select( p => p.Trim() )
			.Where( p => p.Length > 0 );
	}

	static string NormalisePath( string p )
	{
		if ( string.IsNullOrEmpty( p ) ) return "";
		return p.Replace( "\\", "/" ).Trim( '/' );
	}

	public void EnterDirectory( string dir )
	{
		CurrentPath = string.IsNullOrEmpty( CurrentPath ) ? dir : $"{CurrentPath}/{dir}";
		Refresh();
		StateHasChanged();
	}

	public void GoUp()
	{
		if ( !CanGoUp ) return;
		var idx = CurrentPath.LastIndexOf( '/' );
		CurrentPath = idx < 0 ? "" : CurrentPath.Substring( 0, idx );
		Refresh();
		StateHasChanged();
	}

	public void SelectFile( string file )
	{
		SelectedFile = file;
		if ( IsSaveMode && !string.IsNullOrEmpty( file ) ) SaveFileName = file;
		StateHasChanged();
	}

	public void ConfirmFile( string file )
	{
		if ( string.IsNullOrEmpty( file ) ) return;
		var full = string.IsNullOrEmpty( CurrentPath ) ? file : $"{CurrentPath}/{file}";
		var callback = _onSelected;
		Hide();
		callback?.Invoke( full );
	}

	public void Cancel()
	{
		var callback = _onCancelled;
		Hide();
		callback?.Invoke();
	}

	protected override int BuildHash()
	{
		var hc = new HashCode();
		hc.Add( IsOpen );
		hc.Add( CurrentPath );
		hc.Add( SelectedFile );
		hc.Add( Directories.Count );
		hc.Add( Files.Count );
		hc.Add( EmptyMessage );
		hc.Add( Title );
		hc.Add( SystemPath );
		hc.Add( IsSaveMode );
		hc.Add( SaveFileName );
		return hc.ToHashCode();
	}

}
